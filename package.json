{
  "name": "claude-bridge",
  "version": "0.1.0",
  "description": "Discord bot that bridges mentions to Claude Code sessions",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "db:migrate": "bun run scripts/migrate.ts",
    "ram:investigate": "bash scripts/ram-investigation.sh",
    "ram:summary": "bash scripts/ram-trace-summary.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.185",
    "discord.js": "^14.16.0",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "overrides": {
    "zod": "^3.25"
  }
}
