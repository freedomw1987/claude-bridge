{
  "name": "claude-bridge",
  "version": "0.1.0",
  "description": "Discord bot that bridges mentions to Claude Code sessions",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bun run scripts/lint.ts",
    "db:migrate": "bun run scripts/migrate.ts"
  },
  "dependencies": {
    "discord.js": "^14.16.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
