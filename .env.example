# Discord
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_USER_ID=

# Paths
TASKS_ROOT=~/www/discord-claude-tasks
DATA_DIR=./data
PROJECTS_ROOT=~/www
PROJECTS_CONFIG=

# Behaviour
IDLE_TIMEOUT_MIN=30
MAX_CONCURRENT_CONTAINERS=5
GIT_CLONE_TIMEOUT_MIN=5
LOG_LEVEL=info

# Claude Code
CLAUDE_DEFAULT_PERMISSION_MODE=acceptEdits
CLAUDE_SYSTEM_PROMPT_FILE=dev_agent/adapters/claude-code/agent.md

# Claude Agent SDK (Phase 1, parallel to CLI path). Set CLAUDE_USE_SDK=1 to opt in.
# When enabled, the bot uses @anthropic-ai/claude-agent-sdk with custom Discord tools
# (discord_send / discord_typing / discord_react / discord_read_history) instead of
# shelling out to `claude -p --output-format stream-json`. Per-message subprocess
# stream parsing is replaced by per-message query() calls with session resume.
CLAUDE_USE_SDK=0
# Optional SDK overrides (only used when CLAUDE_USE_SDK=1):
# CLAUDE_SDK_MODEL=claude-sonnet-4-6
# CLAUDE_SDK_PERMISSION_MODE=acceptEdits
# Hard cap on a single Claude run. SDK aborts the query when exceeded.
# Default 60 min; lower for tighter SLAs. ADR-0002 future work #2.
# CLAUDE_TURN_TIMEOUT_MS=3600000

# Memory self-watchdog (in-process; exits bot if RSS exceeds threshold).
# Defense-in-depth if the OS-level watchdog (scripts/memory-watchdog.sh)
# plist is disabled. ADR-0002 future work #3.
BOT_RSS_THRESHOLD_MB=800
BOT_RSS_SAMPLE_INTERVAL_MS=30000
# RAM tracing — append RSS + heap samples to data/ram-trace.log as CSV.
# Use to validate SDK-era long-task behavior. ADR-0002 follow-up.
# BOT_RAM_TRACE=1
# BOT_RAM_TRACE_PATH=  # defaults to <DATA_DIR>/ram-trace.log when BOT_RAM_TRACE=1

# Hermes Agent — autonomous project manager (Chair/PM/Worker 3-tier).
# See docs/operations/0003-hermes-agent.md for full design.
HERMES_DIR=                            # empty = <DATA_DIR>/hermes
HERMES_MODEL=claude-haiku-4-5          # planner + judge LLM (cheap)
HERMES_MAX_ITERATIONS=20               # per project
HERMES_MAX_COST_USD=500                # in cents ($5.00); per project
HERMES_MAX_WALL_HOURS=4                # per project
HERMES_MAX_ATTEMPTS_PER_TASK=3         # retries before marking task failed
HERMES_RESUME_ON_STARTUP=1             # 1 = resume active projects on bot start
