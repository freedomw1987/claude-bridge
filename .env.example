# Discord
DISCORD_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_USER_ID=

# Paths
TASKS_ROOT=~/www/discord-claude-tasks
DATA_DIR=./data
PROJECTS_ROOT=~/www
PROJECTS_CONFIG=

# Behaviour
IDLE_TIMEOUT_MIN=30
MAX_CONCURRENT_CONTAINERS=5
GIT_CLONE_TIMEOUT_MIN=5
LOG_LEVEL=info

# Claude Code
CLAUDE_DEFAULT_PERMISSION_MODE=acceptEdits
CLAUDE_SYSTEM_PROMPT_FILE=dev_agent/adapters/claude-code/agent.md

# Claude Agent SDK (Phase 1, parallel to CLI path). Set CLAUDE_USE_SDK=1 to opt in.
# When enabled, the bot uses @anthropic-ai/claude-agent-sdk with custom Discord tools
# (discord_send / discord_typing / discord_react / discord_read_history) instead of
# shelling out to `claude -p --output-format stream-json`. Per-message subprocess
# stream parsing is replaced by per-message query() calls with session resume.
CLAUDE_USE_SDK=0
# Optional SDK overrides (only used when CLAUDE_USE_SDK=1):
# CLAUDE_SDK_MODEL=claude-sonnet-4-6
# CLAUDE_SDK_PERMISSION_MODE=acceptEdits
